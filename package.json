{
  "name": "scripture-app",
  "version": "0.1.0",
  "description": "A local-first, open-source knowledge tool where canonical Scripture is the structured organizing spine.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "node scripts/build-electron.mjs",
    "build:renderer": "node scripts/build-renderer.mjs",
    "dev:renderer": "vite --config vite.config.ts",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.renderer.json",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "library": "node --import tsx src/cli/index.ts",
    "electron": "electron dist/electron/main.js",
    "start": "npm run build && npm run build:renderer && npm run electron",
    "verify:m2": "node --import tsx scripts/verify-m2.ts",
    "verify:m3": "node --import tsx scripts/verify-m3.ts",
    "verify:m4": "node --import tsx scripts/verify-m4.ts",
    "verify:m5": "node --import tsx scripts/verify-m5.ts",
    "verify:m6": "node --import tsx scripts/verify-m6.ts"
  },
  "main": "dist/electron/main.js",
  "bin": {
    "library": "./dist/cli/index.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.4.1",
    "better-sqlite3": "11.9.1",
    "electron": "35.0.1",
    "gray-matter": "4.0.3",
    "pdfjs-dist": "6.1.200",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "ulid": "2.3.0",
    "vite": "6.3.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.15.21",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.5",
    "electron-builder": "26.0.12",
    "esbuild": "0.25.4",
    "tsx": "4.19.4",
    "typescript": "5.8.3"
  }
}
